# ── Auth secrets ───────────────────────────────────────────────────
# Set these before first run. AUTH_SECRET_KEY is auto-generated if omitted.
AUTH_USERNAME=your_username
AUTH_PASSWORD_HASH=<run: python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())">
AUTH_SECRET_KEY=<auto-generated on first run if missing>

# ── Optional ──────────────────────────────────────────────────────
# HF_TOKEN=hf_...
# OLLAMA_BASE_URL=http://localhost:11434
